{
  "expo": {
    "name": "Climb Book",
    "slug": "climb-book-rn-mockup",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "climbbook",
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Manrope_400Regular.ttf",
            "./assets/fonts/Manrope_500Medium.ttf",
            "./assets/fonts/Manrope_600SemiBold.ttf",
            "./assets/fonts/Manrope_700Bold.ttf",
            "./assets/fonts/Manrope_800ExtraBold.ttf"
          ]
        }
      ]
    ],
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF7F1"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
